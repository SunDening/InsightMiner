# HF_ENDPOINT=https://hf-mirror.com
# 强制离线加载模型（模型已缓存，无需联网）。如需下载新模型，注释掉下面两行
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1


# DeepSeek (default LLM provider)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_ID=deepseek-v4-pro
LLM_TIMEOUT=60

# Ollama (alternative provider, set LLM_PROVIDER=ollama to use)
# OLLAMA_MODEL=gemma4:e4b
OLLAMA_MODEL=

DEEPSEEK_API_KEY=

# "deepseek" | "ollama"
LLM_PROVIDER=ollama

TAVILY_API_KEY=

SERPAPI_API_KEY=

LOG_LEVEL=INFO